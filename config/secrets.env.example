# =============================================================================
# Roamlu — Master Secrets File (single source of truth)
# =============================================================================
# Copy this file to `secrets.env` (gitignored) and fill in real values.
# Backend, web admin, and mobile build pipelines all read from here.
#
# Rules:
#   - NEVER commit `secrets.env` (only this `.example`).
#   - All secrets are server-side unless prefixed VITE_ / NEXT_PUBLIC_ / FLUTTER_.
#   - Anything *_PUBLIC_* or VITE_* is shipped to clients — keep it minimal.
#   - Sandbox/live separation is mandatory: SANDBOX_* keys never used in prod.
#   - Webhook signing secrets are required — never trust unsigned webhooks.
# =============================================================================

# -----------------------------------------------------------------------------
# 0 · Environment
# -----------------------------------------------------------------------------
NODE_ENV=development                          # development | staging | production
APP_ENV=sandbox                               # sandbox | live
APP_BASE_URL=https://api.roamlu.com
WEB_ADMIN_URL=https://admin.roamlu.com
MOBILE_DEEP_LINK_SCHEME=roamlu

# -----------------------------------------------------------------------------
# 1 · Database (PostgreSQL 16) — B0/B1
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://roamlu:CHANGE_ME@localhost:5432/roamlu
DATABASE_SSL=false
DATABASE_POOL_MAX=20

# -----------------------------------------------------------------------------
# 2 · Redis / BullMQ — B0
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# -----------------------------------------------------------------------------
# 3 · Auth & Sessions — B3
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_64_CHARS
JWT_ACCESS_TTL_SEC=900                        # 15 min
JWT_REFRESH_TTL_SEC=2592000                   # 30 days
ARGON2_PEPPER=CHANGE_ME_PEPPER_32_CHARS
TOTP_ISSUER=Roamlu

# Admin realm is separate (W1)
ADMIN_JWT_ACCESS_SECRET=CHANGE_ME_ADMIN_ACCESS
ADMIN_JWT_REFRESH_SECRET=CHANGE_ME_ADMIN_REFRESH
ADMIN_SESSION_IDLE_TIMEOUT_SEC=900

# -----------------------------------------------------------------------------
# 4 · Encryption / KMS — B0
# -----------------------------------------------------------------------------
DATA_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES   # AES-256-GCM at-rest field encryption
KMS_PROVIDER=local                              # local | aws | gcp | azure
AWS_KMS_KEY_ID=arn:aws:kms:me-central-1:XXXX:key/XXXX

# -----------------------------------------------------------------------------
# 5 · Email — Transactional (verify, reset, receipts)
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=postmark                       # postmark | sendgrid | ses
POSTMARK_SERVER_TOKEN=YOUR_POSTMARK_TOKEN
SENDGRID_API_KEY=YOUR_SENDGRID_KEY
SES_ACCESS_KEY_ID=YOUR_SES_KEY
SES_SECRET_ACCESS_KEY=YOUR_SES_SECRET
SES_REGION=me-central-1
EMAIL_FROM=no-reply@roamlu.com
EMAIL_REPLY_TO=support@roamlu.com

# -----------------------------------------------------------------------------
# 6 · SMS / Phone Verification & VoIP — B4 / 31–38 / V-01..V-02
# -----------------------------------------------------------------------------
SMS_PROVIDER=twilio                           # twilio | vonage | unifonic (KSA)
TWILIO_ACCOUNT_SID=AC_YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_VERIFY_SERVICE_SID=VA_YOUR_VERIFY_SID
TWILIO_VOICE_APP_SID=AP_YOUR_TWIML_APP_SID
TWILIO_API_KEY_SID=SK_YOUR_API_KEY
TWILIO_API_KEY_SECRET=YOUR_API_SECRET

VONAGE_API_KEY=YOUR_VONAGE_KEY
VONAGE_API_SECRET=YOUR_VONAGE_SECRET
VONAGE_APPLICATION_ID=YOUR_APP_ID
VONAGE_PRIVATE_KEY_PATH=/secrets/vonage-private.key

UNIFONIC_APP_SID=YOUR_UNIFONIC_APP_SID
UNIFONIC_API_KEY=YOUR_UNIFONIC_KEY

# -----------------------------------------------------------------------------
# 7 · Payments / PSP — B4 / 25–27 / G-12
# -----------------------------------------------------------------------------
PSP_PROVIDER=stripe                           # stripe | checkout | tap | hyperpay (KSA) | telr (UAE)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET

CHECKOUT_SECRET_KEY=sk_test_YOUR_CHECKOUT_SECRET
CHECKOUT_PUBLIC_KEY=pk_test_YOUR_CHECKOUT_PUBLIC
CHECKOUT_WEBHOOK_SIGNATURE_KEY=YOUR_CHECKOUT_SIGNING_KEY

TAP_SECRET_KEY=sk_test_YOUR_TAP_SECRET
TAP_PUBLIC_KEY=pk_test_YOUR_TAP_PUBLIC
TAP_WEBHOOK_SECRET=YOUR_TAP_WEBHOOK_SECRET

HYPERPAY_USER_ID=YOUR_HYPERPAY_USER
HYPERPAY_PASSWORD=YOUR_HYPERPAY_PASSWORD
HYPERPAY_ENTITY_ID=YOUR_HYPERPAY_ENTITY
HYPERPAY_ACCESS_TOKEN=YOUR_HYPERPAY_TOKEN

TELR_STORE_ID=YOUR_TELR_STORE
TELR_AUTH_KEY=YOUR_TELR_AUTH_KEY

# Mobile wallets
APPLE_PAY_MERCHANT_ID=merchant.com.roamlu
GOOGLE_PAY_MERCHANT_ID=YOUR_GOOGLE_PAY_ID

# -----------------------------------------------------------------------------
# 8 · eSIM Provider — B7 / 21–30 / E-01..E-03
# -----------------------------------------------------------------------------
ESIM_PROVIDER=airalo                          # airalo | esimgo | 1global | tele2
AIRALO_CLIENT_ID=YOUR_AIRALO_CLIENT_ID
AIRALO_CLIENT_SECRET=YOUR_AIRALO_CLIENT_SECRET
AIRALO_BASE_URL=https://sandbox-partners-api.airalo.com
AIRALO_WEBHOOK_SECRET=YOUR_AIRALO_WEBHOOK_SECRET

ESIMGO_API_KEY=YOUR_ESIMGO_KEY
ESIMGO_BASE_URL=https://api.esim-go.com

ONEGLOBAL_API_KEY=YOUR_1GLOBAL_KEY
ONEGLOBAL_ACCOUNT_ID=YOUR_1GLOBAL_ACCOUNT

# -----------------------------------------------------------------------------
# 9 · VPN Backend — B7 / 39–43 / G-07 / G-11
# -----------------------------------------------------------------------------
VPN_PROVIDER=wireguard                        # wireguard | openvpn | nordlayer
WIREGUARD_CONTROL_API=https://vpn.roamlu.internal
WIREGUARD_API_TOKEN=YOUR_WG_CONTROL_TOKEN
WIREGUARD_SERVER_PRIVATE_KEY=CHANGE_ME_WG_SERVER_KEY
NORDLAYER_API_KEY=YOUR_NORDLAYER_KEY

# -----------------------------------------------------------------------------
# 10 · AI Advisor — B7 / 44–47
# -----------------------------------------------------------------------------
AI_PROVIDER=anthropic                         # anthropic | openai | bedrock
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-4o
AWS_BEDROCK_REGION=me-central-1
AI_DAILY_BUDGET_USD=50                        # caps cost; 429s on exceed

# -----------------------------------------------------------------------------
# 11 · Tax / E-Invoicing — FL
# -----------------------------------------------------------------------------
ZATCA_CSID=YOUR_KSA_ZATCA_CSID                # KSA Phase 2 e-invoicing
ZATCA_PRIVATE_KEY_PATH=/secrets/zatca-key.pem
UAE_FTA_TRN=100123456700003
TAX_PROVIDER=internal                         # internal | avalara | fonoa
AVALARA_ACCOUNT_ID=YOUR_AVALARA_ID
AVALARA_LICENSE_KEY=YOUR_AVALARA_KEY
FONOA_API_KEY=YOUR_FONOA_KEY

# -----------------------------------------------------------------------------
# 12 · Push Notifications — B4 / 20 / G-04
# -----------------------------------------------------------------------------
FCM_PROJECT_ID=roamlu-prod
FCM_SERVICE_ACCOUNT_JSON_PATH=/secrets/fcm-sa.json
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
APNS_KEY_ID=YOUR_APNS_KEY_ID
APNS_PRIVATE_KEY_PATH=/secrets/apns-AuthKey.p8
APNS_BUNDLE_ID=com.roamlu.app
APNS_ENV=sandbox                              # sandbox | production

# -----------------------------------------------------------------------------
# 13 · Object Storage (receipts, exports, ID docs) — B0
# -----------------------------------------------------------------------------
S3_PROVIDER=aws                               # aws | gcs | r2 | minio
S3_REGION=me-central-1
S3_BUCKET=roamlu-prod
S3_ACCESS_KEY_ID=YOUR_S3_KEY
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET
S3_ENDPOINT=                                  # leave blank for AWS

# -----------------------------------------------------------------------------
# 14 · Observability — R1
# -----------------------------------------------------------------------------
SENTRY_DSN=https://YOUR_SENTRY_DSN.ingest.sentry.io/PROJECT
SENTRY_ENVIRONMENT=production
DATADOG_API_KEY=YOUR_DD_KEY
DATADOG_APP_KEY=YOUR_DD_APP_KEY
LOGTAIL_SOURCE_TOKEN=YOUR_LOGTAIL_TOKEN
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.roamlu.internal

# -----------------------------------------------------------------------------
# 15 · Analytics (server-side; client gated by GDPR consent G-06)
# -----------------------------------------------------------------------------
POSTHOG_API_KEY=phc_YOUR_POSTHOG_KEY
POSTHOG_HOST=https://eu.posthog.com
AMPLITUDE_API_KEY=YOUR_AMPLITUDE_KEY

# -----------------------------------------------------------------------------
# 16 · Maps / Geo (coverage detection)
# -----------------------------------------------------------------------------
MAPBOX_ACCESS_TOKEN=pk.YOUR_MAPBOX_TOKEN
GOOGLE_MAPS_API_KEY=YOUR_GMAPS_KEY
IPGEOLOCATION_API_KEY=YOUR_IPGEO_KEY

# -----------------------------------------------------------------------------
# 17 · Customer Support — 63 / 64
# -----------------------------------------------------------------------------
INTERCOM_APP_ID=YOUR_INTERCOM_APP
INTERCOM_API_TOKEN=YOUR_INTERCOM_TOKEN
INTERCOM_IDENTITY_VERIFICATION_SECRET=YOUR_HMAC_SECRET
ZENDESK_SUBDOMAIN=roamlu
ZENDESK_API_TOKEN=YOUR_ZD_TOKEN

# -----------------------------------------------------------------------------
# 18 · Mobile Stores / SDK Config (build-time, not runtime secrets)
# -----------------------------------------------------------------------------
APP_STORE_CONNECT_KEY_ID=YOUR_ASC_KEY_ID
APP_STORE_CONNECT_ISSUER_ID=YOUR_ASC_ISSUER
APP_STORE_CONNECT_PRIVATE_KEY_PATH=/secrets/asc-key.p8
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH=/secrets/play-sa.json
ANDROID_KEYSTORE_PATH=/secrets/roamlu-release.jks
ANDROID_KEYSTORE_PASSWORD=CHANGE_ME
ANDROID_KEY_ALIAS=roamlu
ANDROID_KEY_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# 19 · Captcha / Anti-abuse — Auth flows
# -----------------------------------------------------------------------------
TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET
HCAPTCHA_SITE_KEY=YOUR_HCAPTCHA_SITE
HCAPTCHA_SECRET=YOUR_HCAPTCHA_SECRET

# -----------------------------------------------------------------------------
# 20 · CLIENT-SHIPPED PUBLIC KEYS (safe to expose)
# -----------------------------------------------------------------------------
# Web admin (Vite)
VITE_API_BASE_URL=https://api.roamlu.com
VITE_SENTRY_DSN=https://YOUR_PUBLIC_SENTRY
VITE_POSTHOG_KEY=phc_YOUR_PUBLIC_POSTHOG
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE

# Flutter (--dart-define at build)
FLUTTER_API_BASE_URL=https://api.roamlu.com
FLUTTER_SENTRY_DSN=https://YOUR_PUBLIC_SENTRY
FLUTTER_POSTHOG_KEY=phc_YOUR_PUBLIC_POSTHOG
FLUTTER_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE
FLUTTER_MAPBOX_TOKEN=pk.YOUR_MAPBOX_TOKEN
